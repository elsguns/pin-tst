<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add a vendor stock overview section to the product template form -->
    <record id="view_product_template_form_vendor_stock" model="ir.ui.view">
        <field name="name">product.template.form.vendor_stock</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='purchase']" position="inside">
                <separator string="Vendor Stock Overview"/>
                <field name="seller_ids" mode="tree" readonly="1"
                       widget="one2many"
                       context="{'order_by': 'sequence'}">
                    <tree string="Vendor Stock Overview"
                          decoration-success="vendor_stock &gt; 0"
                          decoration-muted="vendor_stock == 0"
                          editable="bottom"
                          create="false" delete="false">
                        <field name="sequence" widget="handle"/>
                        <field name="partner_id" string="Vendor"/>
                        <field name="vendor_stock"/>
                        <field name="delay"/>
                    </tree>
                </field>
            </xpath>
        </field>
    </record>

</odoo>
