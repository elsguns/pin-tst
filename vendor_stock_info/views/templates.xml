<?xml version="1.0" encoding="utf-8"?>
<odoo>

    
    <record id="product_vendor_stock_info" model="ir.ui.view">
        <field name="name">Vendor Stock Info</field>
        <field name="type">qweb</field>
        <field name="inherit_id" ref="website_sale.product"/>
        <field name="website_id" eval="2"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='product_details']" position="inside">
                <div class="vendor-stock-info mt-3">
                    <h6 class="mb-2">Stock</h6>
                    <p t-if="own_stock" class="mb-2">
                        <span t-out="int(own_stock)"/>
                    </p>
                    <h6 class="mb-2">Lifecycle</h6>
                    <t t-set="lifecycle_fields" t-value="product.sudo().fields_get(['x_studio_lifecycle'])"/>
                    <t t-set="lifecycle" t-value="dict(lifecycle_fields['x_studio_lifecycle']['selection']).get(product.sudo().x_studio_lifecycle)"/>
                    <p t-if="lifecycle" class="mb-2">
                        <span t-out="product.sudo().x_studio_lifecycle"/> -
                        <span t-out="lifecycle"/>
                    </p>
                    <h6 class="mb-2">Availability</h6>
                    <t t-set="avail_fields" t-value="product.sudo().fields_get(['x_studio_availability_hbl'])"/>
                    <t t-set="avail" t-value="dict(avail_fields['x_studio_availability_hbl']['selection']).get(product.sudo().x_studio_availability_hbl)"/>
                    <p t-if="avail" class="mb-2">
                        <span t-out="product.sudo().x_studio_availability_hbl"/> -
                        <span t-out="avail"/>
                    </p>
                    <p t-if="product.availability_msg" class="mb-2" t-att-class="product.availability_msg_class">
                        <t t-out="product.availability_msg"/>
                    </p>
                    <table t-if="vendor_infos" class="table table-sm table-striped mb-0">
                        <thead>
                            <tr>
                                <th>Vendor</th>
                                <th class="text-center">Stock</th>
                                <th class="text-center">Delay</th>
                                <th class="text-center">ETA</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="vendor_infos" t-as="vi">
                                <tr>
                                    <td t-out="vi['partner_id'][1]"/>
                                    <td class="text-center">
                                        <span t-if="vi['vendor_stock'] &gt; 0"
                                              class="badge text-bg-success"
                                              t-out="vi['vendor_stock']"/>
                                        <span t-else=""
                                              class="badge text-bg-secondary">0</span>
                                    </td>
                                    <td class="text-center" t-out="vi['delay']"/>
                                    <td class="text-center" t-out="vi['x_studio_eta']"/>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </xpath>
            <!-- Hide the entire add-to-cart form when buy button should be hidden -->
            <xpath expr="//form[@action='/shop/cart/update']" position="attributes">
                <attribute name="t-if">product.show_buy_button</attribute>
            </xpath>
        </field>
    </record>

</odoo>