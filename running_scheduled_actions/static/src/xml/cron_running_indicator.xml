<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="running_scheduled_actions.CronRunningIndicator">
        <span class="o_cron_running_indicator" style="display:inline-block;width:16px;height:16px;vertical-align:middle;">
            <img t-if="isRunning"
                 src="/running_scheduled_actions/static/src/img/running.gif"
                 alt="Running"
                 style="width:16px;height:16px;display:block;"/>
        </span>
    </t>

</templates>
