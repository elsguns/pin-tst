<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_view_tree_inherit_running" model="ir.ui.view">
        <field name="name">ir.cron.view.tree.inherit.running</field>
        <field name="model">ir.cron</field>
        <field name="inherit_id" ref="base.ir_cron_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='priority']" position="before">
                <field name="is_running" column_invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="ir_cron_view_form_inherit_running" model="ir.ui.view">
        <field name="name">ir.cron.view.form.inherit.running</field>
        <field name="model">ir.cron</field>
        <field name="inherit_id" ref="base.ir_cron_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='active']" position="after">
                <field name="is_running" invisible="1"/>
            </xpath>
            <xpath expr="//button[@name='method_direct_trigger']" position="attributes">
                <attribute name="invisible">state != 'code' or is_running</attribute>
            </xpath>
            <xpath expr="//button[@name='method_direct_trigger']" position="after">
                <div class="btn btn-secondary disabled"
                     role="button"
                     aria-disabled="true"
                     invisible="state != 'code' or not is_running">Running ...</div>
            </xpath>
        </field>
    </record>

    <record id="ir_cron_view_search_inherit_running" model="ir.ui.view">
        <field name="name">ir.cron.view.search.inherit.running</field>
        <field name="model">ir.cron</field>
        <field name="inherit_id" ref="base.ir_cron_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='all']" position="before">
                <filter string="Running" name="is_running" domain="[('is_running', '=', True)]"/>
                <filter string="Not Running" name="is_not_running" domain="[('is_running', '=', False)]"/>
                <separator/>
            </xpath>
        </field>
    </record>
</odoo>
