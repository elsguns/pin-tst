<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Scheduled Action for Google Drive Sync -->
        <record id="cron_gdrive_auto_sync" model="ir.cron">
            <field name="name">Google Drive Auto Sync</field>
            <field name="model_id" ref="model_gdrive_file"/>
            <field name="state">code</field>
            <field name="code">model.sync_google_drive_files()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">False</field>
            <field name="doall">False</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).replace(hour=23, minute=0, second=0)"/>
            <field name="user_id" ref="base.user_root"/>
        </record>

        <!-- Scheduled Action for Auto-Download Product Content -->
        <record id="cron_gdrive_auto_download_products" model="ir.cron">
            <field name="name">Google Drive Auto Download Product Content</field>
            <field name="model_id" ref="model_gdrive_file_registry"/>
            <field name="state">code</field>
            <field name="code">model.auto_download_product_content()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">False</field>
            <field name="doall">False</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).replace(hour=0, minute=0, second=0)"/>
            <field name="user_id" ref="base.user_root"/>
        </record>
        
        <!-- Scheduled Action for Auto-Download Import Data -->
        <record id="cron_gdrive_auto_download_imports" model="ir.cron">
            <field name="name">Google Drive Auto Download Import Data</field>
            <field name="model_id" ref="model_gdrive_file_registry"/>
            <field name="state">code</field>
            <field name="code">model.auto_download_import_data()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">False</field>
            <field name="doall">False</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).replace(hour=2, minute=0, second=0)"/>
            <field name="user_id" ref="base.user_root"/>
        </record>
    </data>
</odoo>