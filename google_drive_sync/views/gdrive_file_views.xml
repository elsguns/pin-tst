<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View -->
        <record id="gdrive_file_tree_view" model="ir.ui.view">
            <field name="name">gdrive.file.tree</field>
            <field name="model">gdrive.file</field>
            <field name="arch" type="xml">
                <tree create="false" edit="false" delete="false">
                    <field name="name"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="gdrive_file_form_view" model="ir.ui.view">
            <field name="name">gdrive.file.form</field>
            <field name="model">gdrive.file</field>
            <field name="arch" type="xml">
                <form create="false" edit="false" delete="false">
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>