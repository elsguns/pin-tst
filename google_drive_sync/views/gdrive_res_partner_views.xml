<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_import_date" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.import.date</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!-- Add to the header area (common for dates) -->
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="gds_last_import_date" readonly="0"/>
            </xpath>
        </field>
    </record>
</odoo>