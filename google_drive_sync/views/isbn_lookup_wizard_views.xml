<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_gdrive_isbn_lookup_wizard_form" model="ir.ui.view">
            <field name="name">gdrive.isbn.lookup.wizard.form</field>
            <field name="model">gdrive.isbn.lookup.wizard</field>
            <field name="arch" type="xml">
                <form string="ISBN Lookup">
                    <!-- Start state -->
                    <group invisible="state != 'start'">
                        <div class="text-muted">
                            <p>Click the button below to fetch all .jpg and .txt files 
                               from folders marked for "Product Images &amp; Descriptions".</p>
                        </div>
                    </group>

                    <!-- Files state: summary -->
                    <div class="alert alert-info" role="alert" invisible="state != 'files'">
                        <strong>Files found: </strong>
                        <field name="total_files" class="d-inline"/>
                    </div>

                    <!-- Files tree -->
                    <field name="file_ids" invisible="state != 'files'" nolabel="1">
                        <tree>
                            <field name="name"/>
                            <field name="file_type"/>
                            <field name="size"/>
                            <field name="drive_file_id" optional="hide"/>
                        </tree>
                    </field>

                    <field name="state" invisible="1"/>

                    <footer>
                        <button string="Fetch Files from Drive" name="action_fetch_files" type="object"
                                class="btn-primary" invisible="state != 'start'"/>
                        <button string="Close" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_gdrive_isbn_lookup" model="ir.actions.act_window">
            <field name="name">ISBN Lookup</field>
            <field name="res_model">gdrive.isbn.lookup.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

    </data>
</odoo>